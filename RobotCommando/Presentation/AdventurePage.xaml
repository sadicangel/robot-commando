<Page x:Class="RobotCommando.Presentation.AdventurePage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:RobotCommando.Presentation"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}"
      mc:Ignorable="d">
  <Page.Resources>
    <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
  </Page.Resources>

  <ScrollViewer IsTabStop="True">
    <Grid utu:SafeArea.Insets="VisibleBounds"
          Padding="24"
          RowSpacing="24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0"
                  Spacing="8">
        <TextBlock Text="Robot Commando"
                   FontSize="34"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding State.LocationDisplay}"
                   FontSize="22"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding State.BlockNumberText}"
                   Opacity="0.72" />
      </StackPanel>

      <Grid x:Name="ContentGrid"
            Grid.Row="1"
            ColumnSpacing="24"
            RowSpacing="24">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition x:Name="StatusColumn"
                            Width="0" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="StoryPanel"
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Spacing="20">
          <Border Padding="24"
                  Background="#112038"
                  BorderBrush="#1F3355"
                  BorderThickness="1"
                  CornerRadius="18">
            <TextBlock Text="{Binding State.PageText}"
                       TextWrapping="Wrap"
                       FontSize="18"
                       LineHeight="30" />
          </Border>

          <StackPanel Spacing="12">
            <TextBlock Text="Scene"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding State.InteractionsSummaryText}"
                       TextWrapping="Wrap" />

            <ItemsControl ItemsSource="{Binding State.Interactions}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,12"
                          Padding="18"
                          Background="#0F1826"
                          BorderBrush="#223247"
                          BorderThickness="1"
                          CornerRadius="16"
                          ToolTipService.ToolTip="{Binding ToolTipText}">
                    <StackPanel Spacing="12">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="12">
                        <Border Width="40"
                                Height="40"
                                Background="#1A2A41"
                                CornerRadius="12">
                          <Viewbox Stretch="Uniform">
                            <TextBlock Margin="10"
                                       Text="{Binding IconGlyph}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                          </Viewbox>
                        </Border>

                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding KindLabel}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Opacity="0.72" />
                          <TextBlock Text="{Binding Title}"
                                     FontSize="18"
                                     FontWeight="SemiBold" />
                        </StackPanel>
                      </StackPanel>

                      <TextBlock Text="{Binding Description}"
                                 TextWrapping="Wrap" />

                      <StackPanel Orientation="Horizontal"
                                  Spacing="8">
                        <Button Content="{Binding PrimaryActionLabel}"
                                Command="{Binding DataContext.ExecuteInteraction, ElementName=Root}"
                                CommandParameter="{Binding Id}" />
                        <Button Content="Escape"
                                Visibility="{Binding CanEscape, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Command="{Binding DataContext.Escape, ElementName=Root}"
                                CommandParameter="{Binding Id}" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Text="Choices"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding State.ChoicesSummaryText}"
                       TextWrapping="Wrap" />

            <ItemsControl ItemsSource="{Binding State.Choices}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Margin="0,0,0,12"
                          Padding="18,14"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Command="{Binding DataContext.SelectChoice, ElementName=Root}"
                          CommandParameter="{Binding Id}"
                          Content="{Binding Text}"
                          IsEnabled="{Binding IsEnabled}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>

        <StackPanel x:Name="StatusPanel"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Spacing="16">
          <Border Padding="18"
                  Background="#0F1826"
                  BorderBrush="#223247"
                  BorderThickness="1"
                  CornerRadius="16">
            <StackPanel Spacing="10">
              <TextBlock Text="Player"
                         FontSize="20"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding State.Player.SkillText}" />
              <TextBlock Text="{Binding State.Player.StaminaText}" />
              <TextBlock Text="{Binding State.Player.LuckText}" />
              <TextBlock Text="{Binding State.Player.RobotSkillText}" />
            </StackPanel>
          </Border>

          <Border Padding="18"
                  Background="#0F1826"
                  BorderBrush="#223247"
                  BorderThickness="1"
                  CornerRadius="16">
            <StackPanel Spacing="10">
              <TextBlock Text="Robot"
                         FontSize="20"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding State.Robot.Name}"
                         FontSize="17"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding State.Robot.Description}"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding State.Robot.ArmorText}" />
              <TextBlock Text="{Binding State.Robot.SpeedText}" />
              <TextBlock Text="{Binding State.Robot.CombatBonusText}" />
              <TextBlock Text="{Binding State.Robot.AbilitiesText}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border Padding="18"
                  Background="#0F1826"
                  BorderBrush="#223247"
                  BorderThickness="1"
                  CornerRadius="16">
            <StackPanel Spacing="10">
              <TextBlock Text="Inventory"
                         FontSize="20"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding State.InventorySummaryText}"
                         TextWrapping="Wrap" />

              <ItemsControl ItemsSource="{Binding State.Inventory}">
                <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,8"
                          ToolTipService.ToolTip="{Binding Description}">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <Border Width="32"
                              Height="32"
                              Margin="0,0,12,0"
                              Background="#1A2A41"
                              CornerRadius="10">
                        <Viewbox Stretch="Uniform">
                          <TextBlock Margin="8"
                                     Text="{Binding IconGlyph}"
                                     FontSize="16"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Viewbox>
                      </Border>

                      <StackPanel Grid.Column="1"
                                  Spacing="2">
                        <TextBlock Text="{Binding Name}" />
                        <TextBlock Text="{Binding Description}"
                                   Opacity="0.72"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <TextBlock Grid.Column="2"
                                 Margin="12,0,0,0"
                                 Text="{Binding QuantityText}"
                                 FontWeight="SemiBold" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </StackPanel>

        <VisualStateManager.VisualStateGroups>
          <VisualStateGroup>
            <VisualState x:Name="Stacked" />
            <VisualState x:Name="Wide">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="960" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="StatusColumn.Width"
                        Value="340" />
                <Setter Target="StoryPanel.(Grid.ColumnSpan)"
                        Value="1" />
                <Setter Target="StatusPanel.(Grid.Row)"
                        Value="0" />
                <Setter Target="StatusPanel.(Grid.Column)"
                        Value="1" />
                <Setter Target="StatusPanel.(Grid.ColumnSpan)"
                        Value="1" />
              </VisualState.Setters>
            </VisualState>
          </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
      </Grid>
    </Grid>
  </ScrollViewer>
</Page>
